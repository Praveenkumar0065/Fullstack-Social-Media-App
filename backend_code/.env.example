APP_NAME=Social Web App API
APP_VERSION=1.0.0

# Comma-separated list of allowed frontend origins.
# Example: https://yourapp.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourapp.vercel.app

# MongoDB Atlas connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=socialsphere

# Auth secrets
AUTH_TOKEN_SECRET=change-me-to-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_REFRESH_TTL_SECONDS=604800

# Optional runtime log level
LOG_LEVEL=INFO
